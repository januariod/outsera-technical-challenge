{
  "name": "outsera-technical-challenge",
  "version": "1.0.0",
  "description": "Suíte completa de automação de testes - Outsera Technical Challenge",
  "keywords": [
    "cypress",
    "k6",
    "cucumber",
    "appium",
    "qa",
    "automation"
  ],
  "homepage": "https://github.com/januariod/outsera-technical-challenge#readme",
  "bugs": {
    "url": "https://github.com/januariod/outsera-technical-challenge/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/januariod/outsera-technical-challenge.git"
  },
  "license": "MIT",
  "author": "Daniel Januario (djanuario@outlook.com.br)",
  "type": "commonjs",
  "scripts": {
    "test:api": "cypress run --project api-tests --reporter mochawesome --reporter-options reportDir=reports/api,overwrite=false,html=false,json=true",
    "test:api:open": "cypress open --project api-tests",
    "test:e2e": "cypress run --project e2e-tests --reporter mochawesome --reporter-options reportDir=reports/e2e,overwrite=false,html=false,json=true",
    "test:e2e:open": "cypress open --project e2e-tests",
    "test:mobile": "npx wdio run mobile-tests/config/wdio.conf.js",
    "test:performance": "k6 run performance-tests/scripts/load-test.js",
    "report": "node scripts/generate-reports.js",
    "report:api": "marge reports/api/*.json -o reports/api -f index --reportTitle 'API Tests - Outsera QA'",
    "report:e2e": "marge reports/e2e/*.json -o reports/e2e -f index --reportTitle 'E2E Tests - Outsera QA'",
    "report:mobile": "marge reports/mobile/*.json -o reports/mobile -f index --reportTitle 'Mobile Tests - Outsera QA'",
    "lint": "eslint . --ext .js --ignore-path .eslintignore",
    "lint:fix": "eslint . --ext .js --ignore-path .eslintignore --fix",
    "prepare": "husky"
  },
  "dependencies": {
    "@faker-js/faker": "^8.3.1",
    "dotenv": "^16.4.5",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.2",
    "@wdio/appium-service": "^9.29.0",
    "@wdio/cli": "^9.29.0",
    "@wdio/local-runner": "^9.29.0",
    "@wdio/mocha-framework": "^9.29.1",
    "@wdio/spec-reporter": "^9.29.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "appium": "^3.5.2",
    "appium-uiautomator2-driver": "^8.0.0",
    "chai": "^4.4.1",
    "chalk": "^4.1.2",
    "cypress": "^15.18.0",
    "cypress-real-events": "^1.13.0",
    "esbuild": "^0.28.1",
    "eslint": "^8.57.0",
    "eslint-plugin-cypress": "^3.3.0",
    "husky": "^9.1.7",
    "lodash": "^4.17.21",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^4.3.0",
    "mochawesome-report-generator": "^6.2.0",
    "wdio-mochawesome-reporter": "^7.0.0",
    "webdriverio": "^9.29.0"
  }
}
