# ============================================================
# Environment Variables - Outsera Technical Challenge
# ============================================================
# Copie este arquivo para .env e preencha os valores reais
# cp .env.example .env

# --- API Base URLs ---
API_BASE_URL=https://restful-booker.herokuapp.com
E2E_BASE_URL=https://restful-booker.herokuapp.com
MOBILE_BASE_URL=https://the-internet.herokuapp.com

# --- Credentials (API / Admin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=password123

# --- Appium ---
APPIUM_HOST=localhost
APPIUM_PORT=4723
ANDROID_DEVICE_NAME=emulator-5554
ANDROID_PLATFORM_VERSION=13.0
IOS_DEVICE_NAME=iPhone 14
IOS_PLATFORM_VERSION=17.0

# --- K6 ---
K6_VUS=500
K6_DURATION=5m

# --- Reports ---
REPORTS_DIR=reports
